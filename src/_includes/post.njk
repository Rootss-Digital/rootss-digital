---
layout: base.njk
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": "https://rootssdigital.com{{ page.url }}#article",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "url": "https://rootssdigital.com{{ page.url }}",
  "datePublished": "{{ date | htmlDateString }}",
  "dateModified": "{{ updated | htmlDateString if updated else date | htmlDateString }}",
  "inLanguage": "en",
  "author": {
    "@id": "https://rootssdigital.com/#sandra"
  },
  "publisher": {
    "@id": "https://rootssdigital.com/#business"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://rootssdigital.com{{ page.url }}"
  },
  "isPartOf": {
    "@id": "https://rootssdigital.com/#website"
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "xPath": [
      "/html/head/title",
      "/html/head/meta[@name='description']",
      "//article//h1",
      "//article//h2"
    ]
  }
}
</script>
<article class="blog-post-page" itemscope itemtype="https://schema.org/BlogPosting">
  <meta itemprop="author" content="Sandra Pablo">
  <meta itemprop="publisher" content="Rootss Digital">

  <header class="post-hero">
    <div class="container container-narrow">
      <div class="post-meta">
        <time itemprop="datePublished" datetime="{{ date | htmlDateString }}">
          <span class="lang-en" lang="en">{{ date | readableDate }}</span>
          <span class="lang-es" lang="es">{{ date | readableDateEs }}</span>
        </time>
        {% if tags %}
        <div class="post-tags" aria-label="Post categories">
          {% for tag in tags %}
            {% if tag != "posts" %}
            <span class="tag">{{ tag }}</span>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
      <h1 itemprop="headline">
        <span class="lang-en" lang="en">{{ title }}</span>
        <span class="lang-es" lang="es">{{ titleEs if titleEs else title }}</span>
      </h1>
      {% if description %}
      <p class="post-excerpt" itemprop="description">
        <span class="lang-en" lang="en">{{ description }}</span>
        <span class="lang-es" lang="es">{{ descriptionEs if descriptionEs else description }}</span>
      </p>
      {% endif %}
    </div>
  </header>

  <div class="post-body container container-narrow" itemprop="articleBody">
    {{ content | safe }}
  </div>

  <aside class="post-author-bio" itemscope itemtype="https://schema.org/Person">
    <div class="container container-narrow">
      <div class="author-bio-inner">
        <img src="/images/sandra-headshot.jpg"
             alt="Sandra Pablo, founder of Rootss Digital, Local SEO strategist in Visalia CA"
             width="72" height="72"
             itemprop="image"
             loading="lazy">
        <div class="author-bio-text">
          <p class="author-bio-name" itemprop="name">
            <span class="lang-en" lang="en">Written by <a href="/about/" itemprop="url">Sandra Pablo</a></span>
            <span class="lang-es" lang="es">Escrito por <a href="/about/" itemprop="url">Sandra Pablo</a></span>
          </p>
          <p class="author-bio-role" itemprop="jobTitle">
            <span class="lang-en" lang="en">Founder of Rootss Digital · Local SEO Strategist · Visalia, CA</span>
            <span class="lang-es" lang="es">Fundadora de Rootss Digital · Estratega de SEO Local · Visalia, CA</span>
          </p>
          <p class="author-bio-desc">
            <span class="lang-en" lang="en">Sandra helps small and family-owned businesses in the Central Valley get found on Google Maps and AI search. Bilingual services in English and Spanish.</span>
            <span class="lang-es" lang="es">Sandra ayuda a pequeños negocios familiares en el Valle Central a ser encontrados en Google Maps y búsquedas de IA. Servicios bilingües en inglés y español.</span>
          </p>
        </div>
      </div>
    </div>
  </aside>

  <aside class="post-cta-banner">
    <div class="container container-narrow">
      <p class="lang-en" lang="en">Is your business showing up on Google? Let's find out together - free.</p>
      <p class="lang-es" lang="es">¿Tu negocio aparece en Google? Averigüémoslo juntos - gratis.</p>
      <a href="/book/" class="btn btn-primary">
        <span class="lang-en" lang="en">Book Your Free Call</span>
        <span class="lang-es" lang="es">Reserva Tu Llamada Gratis</span>
      </a>
    </div>
  </aside>

  <nav class="post-nav" aria-label="Blog navigation">
    <div class="container container-narrow">
      <a href="/blog/" class="post-nav-back">
        <span class="lang-en" lang="en">&larr; Back to Blog</span>
        <span class="lang-es" lang="es">&larr; Volver al Blog</span>
      </a>
    </div>
  </nav>
</article>
